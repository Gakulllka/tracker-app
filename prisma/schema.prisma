generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  displayName  String    @default("")
  status       String    @default("ACTIVE")
  roleId       String
  role         Role      @relation(fields: [roleId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspaces  Workspace[]
  sessions    Session[]
  permissions UserPermission[]
  aiInsights  AiInsight[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  permissions String   @default("{}")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String   @default("Моё пространство")
  allData   String   @default("{}")
  backlog   String   @default("[]")
  questions String   @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  ipAddress    String   @default("")
  lastActivity DateTime @default(now())
  currentPage  String   @default("")
  createdAt    DateTime @default(now())
  expiresAt    DateTime
}

model UserPermission {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  visibleTabs      String   @default("")
  visibleDomainIds String   @default("[]")
  canEdit          Boolean  @default(true)
  canSeeQuestions   Boolean  @default(true)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model Question {
  id           String    @id @default(cuid())
  text         String
  author       String    @default("Аноним")
  answer       String    @default("")
  questionDate DateTime  @default(now())
  answerDate   DateTime?
  createdAt    DateTime  @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String   @default("")
  username   String   @default("")
  action     String
  entityType String   @default("")
  entityId   String   @default("")
  oldValue   String   @default("")
  newValue   String   @default("")
  ipAddress  String   @default("")
  createdAt  DateTime @default(now())
}

// Phase 4: AI-инсайты привязаны к (пользователь, домен, месяц).
// На каждую комбинацию ровно один инсайт; повторное сохранение перезаписывает.
model AiInsight {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domainId     String
  monthKey     String   // "YYYY-MM"

  achievements String   @default("[]") // JSON array
  risks        String   @default("[]") // JSON array
  inProgress   String   @default("[]") // JSON array
  nextSteps    String   @default("[]") // JSON array

  dataHash     String   @default("") // hash задач на момент генерации
  source       String   @default("manual") // "ai" | "manual" | "edited"

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, domainId, monthKey])
  @@index([userId, domainId])
}