generator client {
  provider      = "prisma-client-js"
  // ВАЖНО: без этого Prisma на Netlify Functions падает с
  // "Query engine binary for current platform 'rhel-openssl-3.0.x' could not be found".
  // "native"            — для локальной разработки (Windows/Mac/Linux)
  // "rhel-openssl-3.0.x"  — для Netlify Functions / AWS Lambda Amazon Linux 2023
  // "linux-musl-openssl-3.0.x" — на случай если Netlify когда-то переедет на Alpine
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl нужен только если будешь запускать `prisma migrate deploy` —
  // миграции должны идти мимо пулера PgBouncer.
  // Если переменной нет, Prisma просто использует url.
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(cuid())
  username         String   @unique
  passwordHash     String
  displayName      String   @default("")
  status           String   @default("ACTIVE")
  roleId           String
  role             Role     @relation(fields: [roleId], references: [id])
  selectedDomains  String   @default("[]") // JSON array of domain IDs — какие домены видит пользователь
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  aiInsights  AiInsight[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  permissions String   @default("{}")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Question {
  id           String    @id @default(cuid())
  text         String
  author       String    @default("Аноним")
  answer       String    @default("")
  status       String    @default("open")
  questionDate DateTime  @default(now())
  answerDate   DateTime?
  createdAt    DateTime  @default(now())
}

// Phase 4: AI-инсайты привязаны к (пользователь, домен, месяц).
// На каждую комбинацию ровно один инсайт; повторное сохранение перезаписывает.
model AiInsight {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  domainId String
  monthKey String // "YYYY-MM"

  achievements String @default("[]") // JSON array
  risks        String @default("[]") // JSON array
  inProgress   String @default("[]") // JSON array
  nextSteps    String @default("[]") // JSON array

  dataHash String @default("") // hash задач на момент генерации
  source   String @default("manual") // "ai" | "manual" | "edited"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, domainId, monthKey])
  @@index([userId, domainId])
}

model Domain {
  id          String   @id @default(cuid())
  name        String   @unique
  createdAt   DateTime @default(now())
}

model BacklogItem {
  id          String   @id @default(cuid())
  domainId    String
  num         String   @default("")
  name        String   @default("")
  planH       String   @default("0")
  factH       String   @default("0")
  priority    String   @default("Средний")
  status      String   @default("Идея")
  comment     String   @default("")
  commentLog  String   @default("[]")
  ts          DateTime @default(now())
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([domainId])
}
